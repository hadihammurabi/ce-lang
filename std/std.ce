trait any{}

fn assert(condition bool) !void {
  if condition {
  } else {
    raise "Assertion failed!"
  }
}

fn typeof(x any) string {
  return "unknown"
}

fn malloc<T any>(size uint) *T {
  let dummy T
  return &dummy
}

fn realloc<T any>(ptr *T, new_size uint) *T {
  let dummy T
  return &dummy
}

fn free<T any>(ptr *T) void {}

impl int {
  fn size(self) uint { return 4 }
  fn min(self) int { return -2147483648 }
  fn max(self) int { return 2147483647 }
}

impl i8 {
  fn size(self) uint { return 1 }
  fn min(self) i8 { return -128 }
  fn max(self) i8 { return 127 }
}

impl i16 {
  fn size(self) uint { return 2 }
  fn min(self) i16 { return -32768 }
  fn max(self) i16 { return 32767 }
}

impl i64 {
  fn size(self) uint { return 8 }
  fn max(self) i64 { 
    let zero u64 = 0
    let one u64 = 1
    let two u64 = 2
    let umax u64 = zero - one
    return umax / two
  }
  
  fn min(self) i64 { 
    let zero i64 = 0
    let one i64 = 1
    let zero_u u64 = 0
    let one_u u64 = 1
    let two_u u64 = 2
    let max_i i64 = (zero_u - one_u) / two_u
    return zero - max_i - one
  }
}

impl i128 {
  fn size(self) uint { return 16 }
  fn max(self) i128 { 
    let zero u128 = 0
    let one u128 = 1
    let two u128 = 2
    let umax u128 = zero - one
    return umax / two
  }
  
  fn min(self) i128 { 
    let zero i128 = 0
    let one i128 = 1
    let zero_u u128 = 0
    let one_u u128 = 1
    let two_u u128 = 2
    let max_i i128 = (zero_u - one_u) / two_u
    return zero - max_i - one
  }
}

impl uint {
  fn size(self) uint { return 4 }
  fn min(self) uint { return 0 }
  fn max(self) uint { return 4294967295 }
}

impl u8 {
  fn size(self) uint { return 1 }
  fn min(self) u8 { return 0 }
  fn max(self) u8 { return 255 }
}

impl u16 {
  fn size(self) uint { return 2 }
  fn min(self) u16 { return 0 }
  fn max(self) u16 { return 65535 }
}

impl u64 {
  fn size(self) uint { return 8 }
  fn min(self) u64 { return 0 }
  fn max(self) u64 { 
    let zero u64 = 0
    let one u64 = 1
    return zero - one
  }
}

impl u128 {
  fn size(self) uint { return 16 }
  fn min(self) u128 { return 0 }
  fn max(self) u128 { 
    let zero u128 = 0
    let one u128 = 1
    return zero - one 
  }
}

impl f32 {
  fn size(self) uint { return 4.0 }
  fn min(self) f32 { return -340282346638528859811704183484516925440.0 }
  fn max(self) f32 { return 340282346638528859811704183484516925440.0 }
}

impl float {
  fn size(self) uint { return 8.0 }
  fn min(self) float { return -.0 }
  fn max(self) float { return .0 }
}
